# Note: on the Android emulator "localhost" refers to the emulator itself, not the host
# machine — use http://10.0.2.2:5140 instead when testing against a local API instance.
API_BASE_URL=http://localhost:5140
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
# Optional: override SignalR hub URL (default: {API_BASE_URL}/hubs/notifications)
# SIGNALR_HUB_URL=http://10.0.2.2:5140/hubs/notifications
