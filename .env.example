# Copy this file to .env and fill in your values. Never commit .env (it is in .gitignore).
#
# SWITCHES:
#   ENVIRONMENT: local | production
#   DB_MODE:     local | supabase
#

ENVIRONMENT=local
FRONTEND_URL=http://localhost:5140

DB_MODE=local

# ----- Local PostgreSQL (when DB_MODE=local) -----
DB_HOST=localhost
DB_PORT=5433
DB_NAME=200208
DB_USER=postgres
DB_PASSWORD=your_password_here

# ----- Supabase (when DB_MODE=supabase) -----
DB_SUPABASE_HOST=
DB_SUPABASE_PORT=5432
DB_SUPABASE_NAME=postgres
DB_SUPABASE_USER=
DB_SUPABASE_PASSWORD=

# ----- RabbitMQ -----
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5673
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VIRTUALHOST=/

# ----- SMTP (optional — worker email delivery) -----
SMTP__HOST=smtp.gmail.com
SMTP__PORT=587
SMTP__EMAIL=
SMTP__PASSWORD=
SMTP__USE_SSL=true

# ----- JWT -----
JWT__SECRET_KEY=change_this_to_a_long_random_secret_key_at_least_32_chars
JWT__ISSUER=BridalGlow
JWT__AUDIENCE=BridalGlow

# ----- Stripe (test mode) -----
STRIPE__SECRET_KEY=sk_test_your_key_here
STRIPE__WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ----- Recommender (Worker scheduled jobs) -----
RECOMMENDER_SIMILARITY_RECOMPUTE_INTERVAL_HOURS=24
RECOMMENDER_SNAPSHOT_RECOMPUTE_INTERVAL_HOURS=6

# ----- File uploads (API only) -----
# Optional: absolute path for storing uploaded dress images.
# Defaults to {ContentRootPath}/uploads when not set.
# UPLOAD_PATH=/var/app/uploads
